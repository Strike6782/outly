PORT=8000
NODE_ENV=development

# Frontend origin for CORS (must match Next.js dev port in client/package.json)
CLIENT_URL=http://localhost:3100

# Database connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/outly

# Cache connection string
REDIS_URL=redis://localhost:6379

# Encryption key for credentials
ENCRYPTION_KEY=

# Auth secrets
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=30d

# Google sign-in Client ID
GOOGLE_CLIENT_ID=

# File storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Worker configuration
WORKER_CONCURRENCY=2
MIN_DELAY_MS=5000

# Reply detector poll interval (ms) — default 15 minutes
REPLY_DETECTOR_INTERVAL_MS=900000

# Warmup duration in days
# WARMUP_DURATION_DAYS=28
