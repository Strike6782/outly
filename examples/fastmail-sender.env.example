# Fastmail sender template — copy values into the Add Sender modal
# Do NOT commit real passwords to git.

FASTMAIL_SENDER_EMAIL=you@yourdomain.com
FASTMAIL_APP_PASSWORD=your-app-password-here

SMTP_HOST=smtp.fastmail.com
SMTP_PORT=587
IMAP_HOST=imap.fastmail.com
IMAP_PORT=993

# Recommended production limits (already applied by the app for Fastmail senders)
DAILY_SEND_LIMIT=25
WARMUP_START_DAY_LIMIT=5
